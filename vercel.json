{
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        {
          "key": "Access-Control-Allow-Origin",
          "value": "*"
        }
      ]
    }
  ],
  "rewrites": [
    {
      "source": "/api/pdfs/(.*)",
      "destination": "/api/pdfs?path=$1"
    },
    {
      "source": "/pdfs/(.*)",
      "destination": "/api/pdfs?path=$1"
    }
  ]
}