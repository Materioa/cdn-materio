{
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        {
          "key": "Access-Control-Allow-Origin",
          "value": "*"
        }
      ]
    }
  ],
  "rewrites": [
    {
      "source": "/pdfs/:path*",
      "destination": "https://media.githubusercontent.com/media/Materioa/cdn-materio/main/pdfs/:path*"
    }
  ]
}